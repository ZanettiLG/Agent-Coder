# Agent Coder – variáveis de ambiente (copie para .env e ajuste)
# Uso: cp .env.example .env

# ========== API (servidor) ==========
PORT=3000
HOST=0.0.0.0

# PostgreSQL (obrigatório para escala horizontal; sem isso usa SQLite em backend/data)
DATABASE_URL=postgresql://agentcoder:secret@localhost:5432/agentcoder

# Redis (opcional; para Socket.IO multi-instância)
# REDIS_URL=redis://localhost:6379

# ========== Worker ==========
# ID do projeto que este worker atende (obrigatório quando DATABASE_URL está definido)
# PROJECT_ID=1

# Raiz do repositório (opcional; default: cwd / findGitRoot)
# REPO_ROOT=/app

# URL do servidor para notificar broadcast (default: http://localhost:PORT)
# SERVER_URL=http://localhost:3000

# Chave do CLI Cursor (obrigatória para o agente rodar)
# CURSOR_API_KEY=

# Identificador do processo worker (default: hostname-pid)
# WORKER_ID=

# Intervalo de polling em ms (apenas sem DATABASE_URL)
# WORKER_POLL_MS=5000

# ========== API – listagem de arquivos por projeto ==========
# Path do repositório por project_id (GET /api/repo/files?project_id=N)
# PROJECT_ROOT_1=/var/repos/meu-projeto

# ========== Comum ==========
# Limite de linhas no log da tarefa (GET /api/tasks/:id/log)
# TASK_LOG_MAX_LINES=2000
